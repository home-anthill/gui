{
  "name": "home-anthill",
  "version": "4.0.0",
  "license": "MIT",
  "scripts": {
    "start": "npm run lint && nx serve",
    "build": "npm run lint && npm run build:dev",
    "build:dev": "npm run clean && nx build --configuration=development && npm run clean:dest && npm run copy",
    "build:prod": "npm run clean:dist && nx build --configuration=production",
    "lint": "nx lint",
    "clean": "npm run clean:dist && npm run clean:dest",
    "clean:dist": "rm -rf dist",
    "clean:dest": "rm -rf ../api-server/public",
    "copy": "cpr dist/ ../api-server/public/",
    "test": "nx test",
    "test:coverage": "npx vitest run --coverage",
    "deps": "nx migrate latest"
  },
  "private": true,
  "dependencies": {
    "@mantine/core": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@reduxjs/toolkit": "^2.2.5",
    "@tabler/icons-react": "^3.41.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^7.8.2",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/react": "22.6.5",
    "@nx/vite": "22.6.5",
    "@nx/web": "22.6.5",
    "@nx/workspace": "22.6.5",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.7.10",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "cpr": "^3.0.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "msw": "^2.12.14",
    "nx": "^22.6.5",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.5",
    "vitest": "^4.1.4"
  }
}
